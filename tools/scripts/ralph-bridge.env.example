# Ralph Bridge environment variables
# Copy to ralph-bridge.env and fill in values.
# ralph-bridge.env is loaded by the systemd unit via EnvironmentFile=.

RALPH_BRIDGE_PORT=8765
RALPH_REPO_PATH=/home/nntin/git/gSnake
RALPH_N8N_PATH=/home/nntin/git/gSnake/gsnake-n8n
RALPH_CLAUDE_MD=scripts/ralph/CLAUDE.md
RALPH_PRD_JSON=scripts/ralph/prd.json
RALPH_ARCHIVE_DIR=scripts/ralph/archive
RALPH_STATE_FILE=tools/scripts/ralph-bridge.state.json
RALPH_ITERATION_TIMEOUT=18000
RALPH_WEBHOOK_TOKEN=<generate-with-openssl-rand-hex-32>
